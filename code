#!/bin/sh

set -e

BRANCH="code"
MSG="${1:-Update code}"

echo "==> Checkout $BRANCH"
git checkout "$BRANCH"

echo "==> Pull latest"
git pull --ff-only origin "$BRANCH"

echo "==> Stage files"
git add -A

if git diff --cached --quiet; then
	echo "Nothing to commit."
	exit 0
fi

echo "==> Commit"
git commit -m "$MSG"

echo "==> Push"
git push origin "$BRANCH"

echo
echo "✓ Branch '$BRANCH' updated successfully."