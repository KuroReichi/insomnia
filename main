#!/bin/sh

set -e

BRANCH="main"
SOURCE="code"
MSG="${1:-Merge branch '$SOURCE'}"

echo "==> Checkout $BRANCH"
git checkout "$BRANCH"

echo "==> Pull latest"
git pull --ff-only origin "$BRANCH"

echo "==> Update source branch"
git fetch origin "$SOURCE"

echo "==> Merge"
git merge --no-ff --no-edit "$SOURCE"

echo "==> Push"
git push origin "$BRANCH"

echo
echo "✓ Branch '$BRANCH' merged from '$SOURCE'."